# Copie este arquivo para .env.observabilidade e preencha os valores reais.
# O arquivo .env.observabilidade NÃO deve ser commitado (já está no .gitignore).

# ─── Grafana ────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=SENHA_FORTE_AQUI

# URL pública do Grafana (usada em notificações de alerta e links)
GRAFANA_ROOT_URL=https://grafana.seu-dominio.com

# ─── SMTP para alertas do Grafana (opcional) ────────────────────────────────
GF_SMTP_ENABLED=false
GF_SMTP_HOST=smtp.resend.com:465
GF_SMTP_USER=resend
GF_SMTP_PASSWORD=sua-api-key-resend
GF_SMTP_FROM_ADDRESS=alertas@seu-dominio.com

# ─── Caminho dos logs do PM2 no servidor Linux ──────────────────────────────
# Ajustar para o path real onde o backend está instalado
# Exemplo: /home/ubuntu/plataform-backend/logs
PM2_LOGS_PATH=/home/ubuntu/plataform-backend/logs
